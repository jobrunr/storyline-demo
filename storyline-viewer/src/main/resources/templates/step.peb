<!-- Hide welcome screen via OOB swap -->
<div id="welcome-screen" hx-swap-oob="true" class="content-screen"></div>

<div id="step-{{ step.number }}" class="content-screen active" data-step="{{ step.number }}">
    <div class="level mb-5">
        <div class="level-left">
            <div class="level-item">
                <div>
                    <div class="mb-3">
                        <span class="heading mr-2">Step {{ step.number }} of {{ storyline.storylineMetadata.totalAmountOfSteps }}</span>
                        ·
                        <span class="is-size-6 has-text-grey ml-2">
                            <i class="fas fa-clock"></i> {{ step.estimatedTime.toMinutes }} minutes
                        </span>
                    </div>

                    <h1 class="title is-2">
                        {{ step.title }}
                    </h1>
                </div>
            </div>
        </div>
        <div class="level-right">
            <div class="level-item">
                <button id="btn-complete-{{ step.number }}" class="button is-success" onclick="markStepComplete({{ step.number }})">
                    <span class="icon"><i class="fas fa-check"></i></span>
                    <span>Mark Complete</span>
                </button>
                <button id="btn-incomplete-{{ step.number }}" class="button is-warning" onclick="markStepIncomplete({{ step.number }})" style="display: none;">
                    <span class="icon"><i class="fas fa-undo"></i></span>
                    <span>Mark Incomplete</span>
                </button>
            </div>
        </div>
    </div>

    <!-- The Scenario -->
    {% if step.scenario %}
    <div class="box has-background-light">
        <h3 class="title is-4">The Scenario</h3>
        <div class="is-size-5">{{ step.scenario | raw }}</div>
    </div>
    {% endif %}

    <!-- The Challenge -->
    <div class="box has-background-warning-light">
        <h3 class="title is-4">The Challenge</h3>
        <div class="is-size-5">{{ step.challenge | raw }}</div>
    </div>

    <!-- The Solution -->
    <div class="box has-background-success-light">
        <h3 class="title is-4">The Solution</h3>
        <div class="is-size-5">{{ step.solution | raw }}</div>
        {% if step.learnMore %}
        <p class="mt-4">
            <a href="{{ step.learnMore }}" target="_blank" class="has-text-link">
                <span class="icon"><i class="fas fa-book"></i></span>
                <span>Read the documentation →</span>
            </a>
        </p>
        {% endif %}
    </div>

    <!-- Try It / Dashboard Link -->
    <div class="box has-background-info-light">
        <h3 class="title is-4">Try It Yourself</h3>
        <div class="is-size-5 mb-4">{{ step.tryIt | raw }}</div>
    </div>

    <!-- Toggle between Code and Demo -->
    <div class="tabs is-boxed is-large">
        <ul>
            <li class="tab-link {% if step.codeReferences|length > 0 %}is-active{% endif %}" data-tab="code-{{ step.number }}">
                <a>
                    <span class="icon"><i class="fas fa-code"></i></span>
                    <span>View Code</span>
                </a>
            </li>
            {% if step.tryItUrl %}
            <li class="tab-link" data-tab="demo-{{ step.number }}">
                <a>
                    <span class="icon"><i class="fas fa-play-circle"></i></span>
                    <span>Try Demo</span>
                </a>
            </li>
            {% endif %}
            {% if step.dashboardUrl %}
            <li class="tab-link" data-tab="dashboard-{{ step.number }}">
                <a>
                    <span class="icon"><i class="fas fa-dashboard"></i></span>
                    <span>Dashboard</span>
                </a>
            </li>
            {% endif %}
        </ul>
    </div>

    <!-- Code view -->
    <div id="code-{{ step.number }}" class="tab-content {% if step.codeReferences|length > 0 %}is-active{% endif %}">
        {% if step.codeReferences|length > 0 %}
            <div class="tabs is-boxed mb-0 file-tabs">
                <ul>
                    {% for codeReference in step.codeReferences %}
                    {% set fileName = (codeReference | split('/') | last) | split('\?') | first %}
                    <li class="file-tab {% if loop.first %}is-active{% endif %}"
                        hx-get="/code/{{ codeReference }}"
                        hx-target="#code-pre-{{ step.number }}">
                        <a>
                            <span class="icon is-small"><i class="fas fa-file-code"></i></span>
                            <span>{{ fileName }}</span>
                        </a>
                    </li>
                    {% endfor %}
                </ul>
            </div>
            <div id="code-view-switch" class="code-view-switch-action"></div>
            <pre id="code-pre-{{ step.number }}" class="code-pre p-0"
                 hx-trigger="load" hx-get="/code/{{ step.codeReferences[0] }}"><code class="language-java">Loading code...</code></pre>
        {% else %}
        <div class="notification is-info">
            <p>This step focuses on dashboard exploration. No specific code to display.</p>
        </div>
        {% endif %}
    </div>

    {% if step.tryItUrl %}
    <div id="demo-{{ step.number }}" class="tab-content">
        <div id="demo-container-{{ step.number }}">
            <iframe src="{{ step.tryItUrl }}"
                scrolling="no"
                style="height: 700px; width:100%; border:none; overflow:hidden;">
            </iframe>
        </div>
    </div>
    {% endif %}

    {% if step.dashboardUrl %}
    <div id="dashboard-{{ step.number }}" class="tab-content" style="padding: 0">
        <div id="dashboard-container-{{ step.number }}">
            <iframe src="{{ step.dashboardUrl }}"
                loading="lazy"
                style="height: 700px; width:100%; border:none; ">
            </iframe>
        </div>
    </div>
    {% endif %}


    <!-- Navigation -->
    <div class="buttons is-centered mt-6">
        {% if step.number > 1 %}
        <a href="/storyline/step/{{ step.number - 1 }}" class="button is-light is-medium"
           hx-get="/storyline/step/{{ step.number - 1 }}" hx-target="#step-content" hx-push-url="true" hx-swap="innerHTML show:window:top" preload>
            <span class="icon"><i class="fas fa-arrow-left"></i></span>
            <span>Previous</span>
        </a>
        {% endif %}

        {% if step.number < storyline.storylineMetadata.totalAmountOfSteps %}
        <a href="/storyline/step/{{ step.number + 1 }}" class="button is-primary is-medium"
           hx-get="/storyline/step/{{ step.number + 1 }}" hx-target="#step-content" hx-push-url="true" hx-swap="innerHTML show:window:top" preload>
            <span>Next</span>
            <span class="icon"><i class="fas fa-arrow-right"></i></span>
        </a>
        {% else %}
        <a href="/" class="button is-success is-medium">
            <span class="icon"><i class="fas fa-trophy"></i></span>
            <span>Complete!</span>
        </a>
        {% endif %}
    </div>
</div>
