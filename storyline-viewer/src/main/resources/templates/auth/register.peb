<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Create account - {{ storyline.title }}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bulma@1.0.4/css/bulma.min.css">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
<section class="hero is-fullheight">
    <div class="hero-body">
        <div class="container">
            <div class="columns is-centered">
                <div class="column is-5-tablet is-4-desktop">
                    <div class="box">
                        <div class="has-text-centered mb-6">
                            <img src="/logo.svg" alt="JobRunr" style="max-height: 48px;">
                            <h1 class="title is-4 mt-4 mb-2">Create your account</h1>
                            <p class="subtitle is-6 has-text-grey">We'll send a magic link to sign you in.</p>
                        </div>

                        <form method="post" action="/register">
                            <input type="hidden" name="{{ _csrf.parameterName }}" value="{{ _csrf.token }}">

                            <div class="field mb-4">
                                <label class="label">Full name</label>
                                <div class="control has-icons-left">
                                    <input class="input" type="text" name="name" placeholder="Jane Doe" required autofocus>
                                    <span class="icon is-left"><i class="fas fa-user"></i></span>
                                </div>
                            </div>

                            <div class="field mb-4">
                                <label class="label">Company <span class="has-text-grey">(optional)</span></label>
                                <div class="control has-icons-left">
                                    <input class="input" type="text" name="company" placeholder="Acme Corp">
                                    <span class="icon is-left"><i class="fas fa-building"></i></span>
                                </div>
                            </div>

                            <div class="field mb-4">
                                <label class="label">Email address</label>
                                <div class="control has-icons-left">
                                    <input class="input" type="email" name="email" value="{{ email }}" placeholder="you@example.com" required>
                                    <span class="icon is-left"><i class="fas fa-envelope"></i></span>
                                </div>
                            </div>

                            <button class="button is-primary is-fullwidth mt-4" type="submit">
                                Create account
                            </button>
                        </form>

                        <p class="has-text-centered mt-4 is-size-7 has-text-grey">
                            Already have an account?
                            <a href="/login">Sign in</a>
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/7.0.1/css/all.min.css">
</body>
</html>
