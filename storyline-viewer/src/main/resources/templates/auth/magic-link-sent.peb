<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Check your email - {{ storyline.title }}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bulma@1.0.4/css/bulma.min.css">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
<section class="hero is-fullheight">
    <div class="hero-body">
        <div class="container">
            <div class="columns is-centered">
                <div class="column is-5-tablet is-4-desktop has-text-centered">
                    <div class="box">
                        <span class="icon is-large has-text-primary mb-4" style="font-size: 3rem;">
                            <i class="fas fa-paper-plane"></i>
                        </span>
                        <h1 class="title is-4">Check your inbox</h1>
                        <p class="mb-4">
                            We sent a magic link to <strong>{{ email }}</strong>.<br>
                            Click it to sign in — the link expires in 15 minutes.
                        </p>
                        <p class="is-size-7 has-text-grey">
                            Didn't receive it? Check your spam folder or
                            <a href="/login">try again</a>.
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/7.0.1/css/all.min.css">
</body>
</html>
