<code class="language-java">{{ code }}</code>
{%- if viewSwitch -%}
<div id="code-view-switch" hx-swap-oob="true" class="code-view-switch-action">
    <a hx-get="/code{{ codeFile }}?focus={{ focus }}&show={{ toShow }}" hx-target=".code-pre">{% if toShow == 'all' %}view full file{% else %}view snippet{% endif %}</a>
</div>
{%- endif -%}
