<!DOCTYPE html>
<html>
<head>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Activate Credit Card</title>
    <link rel="stylesheet" href="/style.css">
    <link rel="icon" href="/favicon.svg">
</head>
<body class="flex-center">

<nav class="page-nav">
    <a href="/credit-cards/register">Register Card</a>
    <a href="/credit-cards/activate" class="active">Activate Card</a>
    <a href="/payments/new">Make Payment</a>
</nav>

<div class="card-container">
    <div class="header">
        <h1>Activate Your Credit Card</h1>
        <p>Enter your card details below to activate your card.</p>
    </div>

    <img class="card-image" src="/mastercard.png" alt="Credit card">

    <form action="/credit-cards/activate" method="post">
        <div class="form-field">
            <label for="number">Card Number</label>
            <input type="text" id="number" name="number" placeholder="Enter your 16-digit card number" maxlength="16">
        </div>
        <input type="hidden" name="{{ _csrf.parameterName }}" value="{{ _csrf.token }}">
        <button type="submit" class="submit-btn">
            Activate Card
        </button>
    </form>

    {% if success %}
    <div class="success-message">
        Card activated successfully! You can now start using your card.
    </div>
    {% endif %}
</div>

</body>
</html>
